# URL de la SPA Éléa et base utilisée pour le fallback offline.
EXPO_PUBLIC_MEMORIZATION_URL=https://dev.elea.apps.education.fr/local/memorization/index.php
EXPO_PUBLIC_MEMORIZATION_BASE_URL=https://dev.elea.apps.education.fr/

# Identifiants pour l'auto-login (optionnels).
# Si ces variables sont absentes, l'auto-login est simplement désactivé.
EXPO_PUBLIC_ELEA_LOGIN_USERNAME=
EXPO_PUBLIC_ELEA_LOGIN_PASSWORD=
